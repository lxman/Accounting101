<UserControl x:Class="Accounting101.Views.Create.CreateUSAddressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Accounting101.Views.Create"
             xmlns:views="clr-namespace:Accounting101.Views"
             xmlns:viewModels="clr-namespace:Accounting101.ViewModels"
             xmlns:controls="clr-namespace:Accounting101.Controls"
             mc:Ignorable="d" 
             d:DataContext="viewModels:CreateUSAddressViewModel"
             d:DesignHeight="81" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <controls:TextBoxWithLabelControl
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            LabelContent="Line 1:"
            d:LabelContent="Line 1:" />
        <controls:TextBoxWithLabelControl
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            LabelContent="Line 2:"
            d:LabelContent="Line 2:" />
        <controls:TextBoxWithLabelControl
            Grid.Row="2"
            Grid.Column="0"
            MinWidth="200"
            LabelContent="City:" />
        <controls:ComboBoxWithLabelControl
            x:Name="StateSelector"
            Grid.Row="2"
            Grid.Column="1"
            LabelContent="State:"
            d:Background="White"
            d:Content="State:"/>
        <controls:TextBoxWithLabelControl
            Grid.Row="2"
            Grid.Column="2"
            LabelContent="Zip:" />
    </Grid>
</UserControl>
