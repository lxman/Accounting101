<UserControl x:Class="Accounting101.Controls.LedgerLineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Accounting101.Controls"
             mc:Ignorable="d" 
             d:Background="Teal"
             d:DataContext="{d:DesignInstance local:LedgerLineControl}"
             d:DesignHeight="30" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <local:StyledLabel Grid.Column="0" HorizontalContentAlignment="Left" LabelContent="{Binding When}" d:LabelContent="1/1/2025" />
        <local:StyledLabel Grid.Column="1" HorizontalContentAlignment="Right" LabelContent="{Binding Credit}" d:LabelContent="100.00" />
        <local:StyledLabel Grid.Column="2" LabelContent="{Binding Debit}" />
        <local:StyledLabel Grid.Column="3" HorizontalContentAlignment="Right" LabelContent="{Binding Balance}" d:LabelContent="100.00" />
        <local:StyledLabel Grid.Column="4" HorizontalContentAlignment="Right" LabelContent="{Binding OtherAccountInfo}" d:LabelContent="101 Cash Asset" />
    </Grid>
</UserControl>
