### List available tools
POST https://localhost:7165/mcp
Content-Type: application/json
Accept: text/event-stream

{
  "jsonrpc": "2.0",
  "id": "list_tools_request",
  "method": "list_tools"
}

### Get business information
POST https://localhost:7165/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": "get_business_info_request",
  "method": "call_tool",
  "params": {
    "name": "GetBusinessInfo",
    "arguments": {
      "businessId": "12345"
    }
  }
}

### Get states list
POST https://localhost:7165/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": "get_states_request",
  "method": "call_tool",
  "params": {
    "name": "GetStates"
  }
}

### Get countries list
POST https://localhost:7165/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": "get_countries_request",
  "method": "call_tool",
  "params": {
    "name": "GetCountries"
  }
}

### Create a business
POST https://localhost:7165/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": "create_business_request",
  "method": "call_tool",
  "params": {
    "name": "CreateBusiness",
    "arguments": {
      "businessId": "12345",
      "name": "Acme Corporation",
      "isForeign": false
    }
  }
}

### Get analyze transactions prompt (from AccountingPrompts)
POST https://localhost:7165/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": "analyze_transactions_prompt_request",
  "method": "get_prompt",
  "params": {
    "name": "AnalyzeTransactions",
    "arguments": {
      "transactionData": "2023-05-01,ACCT123,ACCT456,100.00,Payment\n2023-05-02,ACCT456,ACCT789,200.00,Transfer\n2023-05-03,ACCT789,ACCT123,50.00,Refund"
    }
  }
}

### Get generate financial report prompt (from AccountingPrompts)
POST https://localhost:7165/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": "generate_report_prompt_request",
  "method": "get_prompt",
  "params": {
    "name": "GenerateFinancialReport",
    "arguments": {
      "businessName": "Acme Corp",
      "timePeriod": "Q2 2023",
      "financialData": "Revenue: $500,000\nExpenses: $300,000\nProfit: $200,000\nAssets: $1,200,000\nLiabilities: $800,000"
    }
  }
}
