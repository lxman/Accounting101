<Window x:Class="Accounting101.Dialogs.GetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStyle="None"
        Height="75" Width="200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Enter Password" FontSize="16" HorizontalAlignment="Center" />
        <PasswordBox Grid.Row="1" x:Name="PasswordBox" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" KeyDown="PasswordBoxKeyDown" d:Password="1234" />
    </Grid>
</Window>