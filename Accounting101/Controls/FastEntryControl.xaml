<UserControl x:Class="Accounting101.Controls.FastEntryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Accounting101.Controls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" 
             d:Background="Teal"
             d:DataContext="{d:DesignInstance local:FastEntryControl}"
             Background="Transparent"
             MinHeight="40"
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <DatePicker Grid.Column="0" VerticalContentAlignment="Center" mah:ControlsHelper.CornerRadius="10" IsTabStop="True" />
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,10,0">
            <RadioButton Content="Credit" Background="Transparent" Foreground="{StaticResource MahApps.Brushes.IdealForeground}" IsTabStop="True" IsChecked="{Binding Credit}" />
            <RadioButton Content="Debit" Background="Transparent" Foreground="{StaticResource MahApps.Brushes.IdealForeground}" IsTabStop="True" IsChecked="{Binding Debit}" />
        </StackPanel>
        <ComboBox Grid.Column="2" MinWidth="200" mah:ControlsHelper.CornerRadius="10" IsTabStop="True" ItemsSource="{Binding OtherAccounts}" SelectedItem="{Binding OtherAccount}" />
        <TextBox Grid.Column="3" mah:ControlsHelper.CornerRadius="10" IsTabStop="True" Text="{Binding Amount}" />
        <Button
            Grid.Column="4"
            Padding="20,0,20,0"
            Content="_Accept"
            IsTabStop="True"
            Background="Transparent"
            Foreground="{StaticResource MahApps.Brushes.IdealForeground}"
            mah:ControlsHelper.CornerRadius="10" />
    </Grid>
</UserControl>
