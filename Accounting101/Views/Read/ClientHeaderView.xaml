<UserControl x:Class="Accounting101.Views.Read.ClientHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:read="clr-namespace:Accounting101.Views.Read"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:Background="Teal"
             d:DataContext="{d:DesignInstance read:ClientHeaderView}"
             d:DesignHeight="160" d:DesignWidth="800"
             PreviewMouseDown="ClientHeaderViewPreviewMouseDown"
             Background="{DynamicResource MahApps.Brushes.Accent}"
             Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
             mah:ControlsHelper.CornerRadius="10">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label
            Grid.Column="0"
            Grid.Row="0"
            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}">
            Business Name
        </Label>
        <TextBlock
            Grid.Column="1"
            Grid.Row="0"
            VerticalAlignment="Center"
            Margin="10,0,0,0"
            Text="{Binding BusinessName}"
            d:Text="Joe's Pool Hall" />
        <Label
            Grid.Column="0"
            Grid.Row="1"
            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}">
            Contact
        </Label>
        <TextBlock
            Grid.Column="1"
            Grid.Row="1"
            VerticalAlignment="Center"
            Margin="10,0,0,0"
            Text="{Binding Contact}"
            d:Text="Mr. Joseph J. Johnston Sr." />
        <Label
            Grid.Column="0"
            Grid.Row="2"
            VerticalAlignment="Top"
            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}">
            Address
        </Label>
        <TextBlock
            Grid.Column="1"
            Grid.Row="2"
            Margin="10,8,0,0"
            Text="{Binding Address}" />
    </Grid>
</UserControl>