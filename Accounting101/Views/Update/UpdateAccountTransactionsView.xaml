<UserControl x:Class="Accounting101.Views.Update.UpdateAccountTransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:update="clr-namespace:Accounting101.ViewModels.Update"
             xmlns:controls="clr-namespace:Accounting101.Controls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance update:UpdateAccountTransactionsViewModel}"
             d:Background="Teal"
             Background="Transparent"
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="Self">
    <UserControl.Resources>
        <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource MahApps.Styles.ListBoxItem}">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Column="0" Grid.Row="0" Background="{DynamicResource MahApps.Brushes.SystemControlBackgroundAccent}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <controls:StyledLabel x:Name="Date" Grid.Column="0" Grid.Row="0" LabelContent="Date" />
            <controls:StyledLabel x:Name="Credit" Grid.Column="1" Grid.Row="0" HorizontalContentAlignment="Right" LabelContent="Credit" />
            <controls:StyledLabel x:Name="Debit" Grid.Column="2" Grid.Row="0" HorizontalContentAlignment="Right" LabelContent="Debit" />
            <controls:StyledLabel x:Name="Balance" Grid.Column="3" Grid.Row="0" HorizontalContentAlignment="Right" LabelContent="Balance" />
            <controls:StyledLabel Grid.Column="4" Grid.Row="0" HorizontalContentAlignment="Right" LabelContent="Other Account" />
        </Grid>
        <ListBox
            Grid.Column="0"
            Grid.Row="1"
            ItemsSource="{Binding Transactions}"
            SelectedItem="{Binding SelectedLine}"
            SelectionMode="Single"
            Background="Transparent" />
    </Grid>
</UserControl>