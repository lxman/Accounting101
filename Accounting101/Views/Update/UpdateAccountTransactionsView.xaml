<UserControl x:Class="Accounting101.Views.Update.UpdateAccountTransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:update="clr-namespace:Accounting101.ViewModels.Update"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance update:UpdateAccountTransactionsViewModel}"
             d:Background="Teal"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <DataGrid
            mah:DataGridHelper.SelectionUnit="FullRow"
            CanUserSortColumns="False"
            AutoGenerateColumns="True"
            AutoGeneratingColumn="DataGridAutoGeneratingColumn"
            AutoGeneratedColumns="DataGridAutoGeneratedColumns"
            LoadingRow="DataGridLoadingRow"
            HorizontalScrollBarVisibility="Hidden"
            VerticalScrollBarVisibility="Auto"
            GridLinesVisibility="None"
            ItemsSource="{Binding Transactions}"
            SelectedItem="{Binding SelectedLine, Mode=OneWayToSource}"
            SelectionMode="Single"
            SelectionUnit="FullRow"
            RowBackground="Transparent"
            HeadersVisibility="Column"
            IsReadOnly="True"
            Style="{x:Null}"
            Foreground="Black"
            Background="White" />
    </Grid>
</UserControl>