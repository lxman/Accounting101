<UserControl x:Class="Accounting101.Controls.LedgerLineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Accounting101.Controls"
             mc:Ignorable="d"
             d:Background="Teal"
             d:DataContext="{d:DesignInstance local:LedgerLineControl}"
             Background="Transparent"
             d:DesignHeight="30" d:DesignWidth="800"
             x:Name="Self">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <local:StyledLabel x:Name="DateWidth" Grid.Column="0" HorizontalContentAlignment="Left" LabelContent="{Binding When, Mode=OneWay, ElementName=Self}" d:LabelContent="1/1/2025" />
        <local:StyledLabel x:Name="CreditWidth" Grid.Column="1" HorizontalContentAlignment="Right" LabelContent="{Binding Credit, Mode=OneWay, ElementName=Self}" d:LabelContent="100.00" />
        <local:StyledLabel x:Name="DebitWidth" Grid.Column="2" HorizontalContentAlignment="Right" LabelContent="{Binding Debit, Mode=OneWay, ElementName=Self}" />
        <local:StyledLabel x:Name="BalanceWidth" Grid.Column="3" HorizontalContentAlignment="Right" LabelContent="{Binding Balance, Mode=OneWay, ElementName=Self}" d:LabelContent="100.00" />
        <local:StyledLabel Grid.Column="4" HorizontalContentAlignment="Right" LabelContent="{Binding OtherAccountInfo, Mode=OneWay, ElementName=Self}" d:LabelContent="101 Cash Asset" />
    </Grid>
</UserControl>