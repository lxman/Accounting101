<UserControl x:Class="Accounting101.Controls.StyledLabel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Accounting101.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:StyledLabel}"
             d:Background="Teal"
             Background="Transparent"
             d:DesignHeight="25" d:DesignWidth="50">
    <Label
        Content="{Binding LabelContent}"
        d:Content="{Binding LabelContent}"
        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}" />
</UserControl>