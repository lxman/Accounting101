<UserControl x:Class="Accounting101.Controls.TextBlockWithLabelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Accounting101.Controls"
             mc:Ignorable="d" 
             x:Name="Self"
             d:DesignHeight="25" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Label
            Grid.Column="0"
            x:Name="Label"
            Padding="5, 5, 5, 0"
            Content="{Binding LabelContent, ElementName=Self}"
            d:Content="Label:"
            d:Background="White" />
        <TextBlock
            Grid.Column="1"
            x:Name="TextBlock"
            Padding="5"
            Text="{Binding TextBlockContent, ElementName=Self}"
            d:Text="TextBlock"
            d:Background="White" />
    </Grid>
</UserControl>
